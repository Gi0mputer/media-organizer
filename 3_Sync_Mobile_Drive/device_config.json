{
  "activeDevice": "iphone",
  "iphone": {
    "model": "iPhone",
    "notes": "Nuovo device (Mar 2026). Su Windows: usa iCloud Photos per il subset _gallery e SSD exFAT (Files) per il subset _mobile. Vedi IPHONE_WINDOWS.md.",
    "transfer": {
      "gallery": "iCloud Photos (iCloud for Windows) / app transfer / import manuale",
      "mobile": "SSD esterno exFAT (Files) / cloud drive"
    },
    "icloudPhotos": {
      "enabled": true,
      "photosRoot": "",
      "photosRootCandidates": [
        "%USERPROFILE%\\Pictures\\iCloud Photos\\Photos",
        "%USERPROFILE%\\Pictures\\iCloud Photos\\Downloads",
        "%USERPROFILE%\\Pictures\\iCloud Photos"
      ]
    },
    "inbox": {
      "path": "E:\\_iphone_inbox",
      "grouping": "Month",
      "script": "3_Sync_Mobile_Drive/Import-iCloudPhotos-ToInbox.ps1"
    }
  },
  "phone": {
    "model": "Google Pixel 8",
    "paths": {
      "mobileRoot": "/sdcard/SSD",
      "galleryRoot": "/sdcard/DCIM/SSD"
    },
    "notes": "LEGACY: configurazione ADB Dual-Root (Gen 2026). mobileRoot=Archivio, galleryRoot=Visibile in Google Foto."
  },
  "disks": {
    "recent": {
      "path": "E:\\",
      "description": "SSD Recente (2024-Oggi)"
    },
    "old": {
      "path": "D:\\",
      "description": "SSD Archivio (2018-2023)"
    }
  },
  "syncSettings": {
    "excludeExtensions": [
      ".tmp",
      ".bak",
      ".db",
      ".ini"
    ],
    "adb": {
      "pushArgs": "",
      "pullArgs": ""
    }
  }
}
